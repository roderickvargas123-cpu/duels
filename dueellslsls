if getgenv().GhostTriggerBot then return end
getgenv().GhostTriggerBot = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local holdingTriggerButton = false
local ejecutandoMacro = false

-- ==========================================
-- INTERFAZ GRÁFICA (OCULTA EN COREGUI)
-- ==========================================
local hiddenUI = (gethui and gethui()) or CoreGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "GhostGUI"
screenGui.Parent = hiddenUI

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 70)
frame.Position = UDim2.new(0.02, 0, 0.05, 0)
frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
frame.BorderSizePixel = 2
frame.BorderColor3 = Color3.fromRGB(255, 0, 0)
frame.Parent = screenGui

local textLabel = Instance.new("TextLabel")
textLabel.Size = UDim2.new(1, 0, 0, 40)
textLabel.BackgroundTransparency = 1
textLabel.Text = "[ GHOST + SPHERE: Hold 'P' ]"
textLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
textLabel.Font = Enum.Font.Code
textLabel.TextSize = 13
textLabel.Parent = frame

local hideLabel = Instance.new("TextLabel")
hideLabel.Size = UDim2.new(1, 0, 0, 20)
hideLabel.Position = UDim2.new(0, 0, 0, 40)
hideLabel.BackgroundTransparency = 1
hideLabel.Text = "[INSERT] para Ocultar Menú"
hideLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
hideLabel.Font = Enum.Font.SourceSans
hideLabel.TextSize = 14
hideLabel.Parent = frame

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Insert then
        screenGui.Enabled = not screenGui.Enabled
    end

    if not gameProcessed and input.KeyCode == Enum.KeyCode.P then
        holdingTriggerButton = true
        frame.BorderColor3 = Color3.fromRGB(0, 255, 255)
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.P then
        holdingTriggerButton = false
        frame.BorderColor3 = Color3.fromRGB(255, 0, 0)
    end
end)

-- ==========================================
-- MACRO: BYPASS ANTI-CHEAT (Solo Extraer y Disparar)
-- ==========================================
local function GhostShoot()
    if ejecutandoMacro then return end
    ejecutandoMacro = true

    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Two, false, game)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Two, false, game)
    
    task.wait(0.06) 
    
    if mouse1click then
        mouse1click()
    else
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end
    
    task.wait(0.5)
    ejecutandoMacro = false
end

-- ==========================================
-- MOTOR PRINCIPAL: SPHERECAST (Indetectable)
-- ==========================================
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude
rayParams.IgnoreWater = true

RunService.Heartbeat:Connect(function()
    if holdingTriggerButton and getgenv().GhostTriggerBot and LocalPlayer.Character then
        
        rayParams.FilterDescendantsInstances = {LocalPlayer.Character}

        local mousePos = UserInputService:GetMouseLocation()
        local unitRay = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
        
        -- ==========================================
        -- REEMPLAZO DEL HITBOX EXPANDER POR SPHERECAST
        -- ==========================================
        -- Disparamos un cilindro invisible con el radio exacto de 1.05
        -- Los cuerpos de los enemigos permanecen intactos, evadiendo el Anti-Cheat.
        local rayResult = workspace:Spherecast(unitRay.Origin, 1.05, unitRay.Direction * 1000, rayParams)
        
        if rayResult and rayResult.Instance then
            local model = rayResult.Instance:FindFirstAncestorOfClass("Model")
            
            if model and model:FindFirstChild("Humanoid") and model.Humanoid.Health > 0 then
                local targetPlayer = Players:GetPlayerFromCharacter(model)
                
                if targetPlayer then
                    GhostShoot()
                end
            end
        end
    end
end)
