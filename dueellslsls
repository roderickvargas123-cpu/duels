local randomSignature = "Sys_" .. tostring(math.random(10000, 99999))
if getgenv()[randomSignature] then return end
getgenv()[randomSignature] = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local holdingTriggerButton = false
local ejecutandoMacro = false

-- ==========================================
-- 2. MODO HEADLESS (Sin rastro visual)
-- ==========================================
-- Se eliminó por completo el CoreGui, ScreenGui y TextLabels.
-- Operación 100% en la sombra. Cero instancias creadas.

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    -- Quitamos el Insert, solo queda el gatillo oculto en 'P'
    if not gameProcessed and input.KeyCode == Enum.KeyCode.P then
        holdingTriggerButton = true
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.P then
        holdingTriggerButton = false
    end
end)

local function GhostShoot()
    if ejecutandoMacro then return end
    ejecutandoMacro = true

    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Two, false, game)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Two, false, game)
    
    -- Variación de ms aumentada para engañar detectores de tiempo
    task.wait(math.random(50, 85) / 1000) 
    
    if mouse1click then
        pcall(mouse1click) -- Usamos pcall para interceptar y ocultar cualquier error que el AC intente forzar
    else
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end
    
    task.wait(math.random(450, 650) / 1000)
    ejecutandoMacro = false
end

-- ==========================================
-- 3. THROTTLING DEL MOTOR (Evadir escaneo de rendimiento)
-- ==========================================
local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude
rayParams.IgnoreWater = true

local lastScan = tick()

RunService.RenderStepped:Connect(function()
    if holdingTriggerButton and getgenv()[randomSignature] and LocalPlayer.Character then
        
        -- Throttling: En lugar de escanear a 60fps constantes, escaneamos con variaciones
        -- Esto rompe los patrones de detección basados en Heartbeat/RenderStepped
        if tick() - lastScan < 0.025 then return end
        lastScan = tick()

        rayParams.FilterDescendantsInstances = {LocalPlayer.Character}

        local mousePos = UserInputService:GetMouseLocation()
        local unitRay = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
        
        -- Mantenemos el Spherecast de radio 1.05
        local rayResult = workspace:Spherecast(unitRay.Origin, 1.05, unitRay.Direction * 1000, rayParams)
        
        if rayResult and rayResult.Instance then
            local model = rayResult.Instance:FindFirstAncestorOfClass("Model")
            
            if model and model:FindFirstChild("Humanoid") and model.Humanoid.Health > 0 then
                local targetPlayer = Players:GetPlayerFromCharacter(model)
                
                if targetPlayer then
                    GhostShoot()
                end
            end
        end
    end
end)
